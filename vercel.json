{
  "rewrites": [
    { "source": "/host/settings/:listingId/form", "destination": "/api/host/settings/:listingId/form" },
    { "source": "/host/settings/:listingId", "destination": "/api/host/settings/:listingId" },
    { "source": "/guide/:listing/experience/:experience", "destination": "/index.html" },
    { "source": "/guide/:listing", "destination": "/index.html" },
    { "source": "/guide/:path*/js/:file*", "destination": "/js/:file*" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
