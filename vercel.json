{
  "functions": {
    "api/host/settings/[listingId]/form.js": {
      "includeFiles": "{partials/**,js/presets/**,js/rec-slots.js}"
    },
    "api/host/settings/[listingId].js": {
      "includeFiles": "{partials/**,js/presets/**,js/rec-slots.js}"
    }
  },
  "rewrites": [
    { "source": "/api/tourism/nearby", "destination": "/api/search/experiences?__tdxNearby=1" },
    { "source": "/api/search/listing-property", "destination": "/api/search/experience-details?__listingProperty=1" },
    { "source": "/api/auth/:path*", "destination": "/api/health?__auth=1&authPath=:path*" },
    { "source": "/host/settings/:listingId/form", "destination": "/api/host/settings/:listingId/form" },
    { "source": "/host/settings/:listingId", "destination": "/api/host/settings/:listingId" },
    { "source": "/guide/:listing/experience/:experience", "destination": "/index.html" },
    { "source": "/guide/:listing", "destination": "/index.html" },
    { "source": "/guide/:path*/js/:file*", "destination": "/js/:file*" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Permissions-Policy", "value": "geolocation=(self)" }
      ]
    }
  ]
}
