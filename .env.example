# SearchAPI — optional; experience search only (listing autofill scrapes Airbnb HTML directly)
SEARCHAPI_KEY=

# TDX Tourism Nearby — https://tdx.transportdata.tw/user/dataservice/key
# X = longitude, Y = latitude; filled from the visitor's geolocation in the browser
TDX_CLIENT_ID=
TDX_CLIENT_SECRET=

# Resend — booking confirmation email (https://resend.com)
RESEND_API_KEY=
FROM_EMAIL=Host Pocket <bookings@yourdomain.com>

# Gmail SMTP — alternative to Resend
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_APP_PASSWORD=
# SMTP_FROM=Host Pocket <you@gmail.com>

PORT=3000

# Google login (OAuth Web client) — 會員專區
# Console: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs 需包含 GOOGLE_REDIRECT_URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback
# 簽 session cookie 用（請改成隨機長字串）
SESSION_SECRET=

# 全權白名單（選用）— 啟動時 seed 進 DB 表 vip_emails；正式以 DB 為準
# 建表：supabase/vip_emails.sql（ensureSchema 也會自動建）
# 手動：INSERT INTO vip_emails (email, note) VALUES ('friend@gmail.com', '好友');
# 例：HOST_POCKET_VIP_EMAILS=you@gmail.com,friend@gmail.com
HOST_POCKET_VIP_EMAILS=

# Postgres — Supabase (recommended) or any Postgres-compatible host
#
# 1) 建表：Supabase → SQL Editor → 執行 listing_settings.sql、users.sql、user_listings.sql、vip_emails.sql
# 2) 連線：Supabase → Connect → Transaction pooler → URI（port 6543）
#    勿用 Direct (db.*.supabase.co)：新專案常僅 IPv6，本機易 getaddrinfo ENOTFOUND
# 3) 密碼含 & # 等請 URL encode（& → %26）
#
# Example:
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=
# POSTGRES_URL=   # alias accepted by this project

# Live Server / 靜態伺服器跨域（預設已含 5500、8080）
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:8080,http://localhost:8080

# Public site URL — used for ECPay ReturnURL / OrderResultURL
# Local: http://localhost:3000
# Vercel: https://your-app.vercel.app (or set automatically via VERCEL_URL)
PUBLIC_BASE_URL=http://localhost:3000

# 「快速開始」preset JSON（js/presets/*.json）
# 本機預設可寫回檔案；Vercel 唯讀，會改寫 listing_settings。設 0 可強制不寫檔。
# PRESETS_WRITABLE=1

# ECPay（綠界）— 體驗預定與 Host Pocket 月費（「訂閱月費」）
# 預設 ECPAY_MODE=stage 會使用官方測試特店（免申請、免設 ECPAY_USE_STAGE）
# 若要關閉 stage：ECPAY_USE_STAGE=0
# 正式收款：向綠界申請後填 MerchantID / HashKey / HashIV，並設 ECPAY_MODE=production
ECPAY_MODE=stage
# ECPAY_USE_STAGE=1
# ECPAY_MERCHANT_ID=
# ECPAY_HASH_KEY=
# ECPAY_HASH_IV=
# 非 NT$ 標價時的預設收款金額（整數、新台幣）
ECPAY_DEFAULT_AMOUNT=100
# Host Pocket 月費（定價面板「開始設定」）
HOST_POCKET_MONTHLY_AMOUNT=40
