# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Enable: Google Calendar API
GOOGLE_CLIENT_ID=930259518533-564dolrm2d6juoh5ckn5o3q2c3omvq03.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback
# Production (Vercel): also add this URI in Google Cloud Console:
# https://host-pocket.vercel.app/oauth2callback

# Run once: npm run google:auth
GOOGLE_REFRESH_TOKEN=

# Calendar to create events on (usually primary)
GOOGLE_CALENDAR_ID=primary

# Optional — custom branded email via Resend (https://resend.com)
# Without this, Google Calendar still emails the guest a calendar invite with Meet link.
RESEND_API_KEY=
FROM_EMAIL=Host Pocket <work223305@gmail.com>

# Gmail SMTP — booking confirmation (alternative to Resend; works without Google OAuth)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_APP_PASSWORD=
# SMTP_FROM=Host Pocket <you@gmail.com>

PORT=3000

# Live Server / 靜態伺服器跨域（預設已含 5500、8080）
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:8080,http://localhost:8080
